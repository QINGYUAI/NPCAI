# 服务器配置
PORT=3000

# MySQL 数据库配置（远程服务器）
# 密码从服务器管理员获取后填入本地 .env，切勿提交
DB_HOST=101.126.17.104
DB_PORT=3306
DB_USER=ainpc
DB_PASSWORD=root
DB_NAME=ainpc

# M4.1 引擎配置
ENGINE_ENABLED=true
ENGINE_DEFAULT_INTERVAL_MS=30000
ENGINE_MAX_CONCURRENCY=8
ENGINE_LOG_RETENTION=2000

# M4.2.2 记忆向量化配置
# 向量维度必须与 Qdrant collection 一致，换模型须重建 collection
MEMORY_EMBED_ENABLED=true
MEMORY_EMBED_MODEL=text-embedding-3-small
MEMORY_EMBED_DIM=1536
MEMORY_TOP_K=5
MEMORY_RETENTION_DAYS=30
# M4.2.2.c Y2 指针式：指向 ai_config 表某条专用 embedding 记录的 id
# - 0 或留空 = 禁用，embedText 复用 NPC 绑定的 chat ai_config（默认）
# - 典型场景：DeepSeek 无 embedding → 这里指向通义千问/智谱的 ai_config
#   并把 MEMORY_EMBED_MODEL 改成该 provider 的 embedding 模型名（如 text-embedding-v1）
MEMORY_EMBED_AI_CONFIG_ID=0

# Qdrant 向量库；未启动时 retrieve 会降级到 MySQL，store 会标 pending
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=npc_memory
QDRANT_VECTOR_SIZE=1536

# 磁盘 embedding 缓存
EMBED_CACHE_ENABLED=true
EMBED_CACHE_TTL_DAYS=30
EMBED_CACHE_DIR=.cache/embed

# M4.2.3 反思循环
# 每 N tick 为每个 NPC 触发一次反思，0 = 关闭自动反思（仍支持手动 API）
REFLECT_EVERY_N_TICK=5
# 反思参考的最近 K 条 npc_memory（按 created_at DESC，全 type）
REFLECT_RECENT_MEMORY_K=20

# M4.2.4 事件总线
# tick 头 event-intake 节点读「最近 N 秒内未被本 NPC 消费」的事件（拉票 Q2b 依据 scene_event_consumed 精确去重）
# [M4.4.0 Q2a] 默认值从 60 → 120 秒；配合混合窗口解 budget skip 拉长 tick 间隔致对话链断
EVENT_LOOKBACK_SECONDS=120
# [M4.4.0 Q2a] 混合窗口条数条件：拉「最近 N 条」事件，与时间窗取并集（OR），任一满足即返回
# 典型值 50；0 = 关闭条数窗（纯时间窗，回 M4.3 行为）
EVENT_LOOKBACK_COUNT=50
# 单 tick 单 NPC 最多注入到 plan prompt 的事件数（按 created_at DESC 取新）
EVENT_MAX_PER_TICK=10
# 事件子系统总开关：false = event-intake 彻底短路（不查库、不注入），便于 A/B 与临时禁用
EVENT_BUS_ENABLED=true

# M4.3.0 trace_id 贯穿
# tick 顶部生成 uuid v4，贯穿 5 张表（npc_tick_log/ai_call_log/scene_event/npc_memory/npc_reflection）
# false = 所有字段写 NULL，完全回退到 M4.2 行为（一键回滚开关）
TRACE_ID_ENABLED=true
# 日志打印格式：short=仅首 8 字节缩写（默认，减少噪音）；full=完整 uuid（排障用）
TRACE_ID_LOG_FORMAT=short

# M4.3.1.a 多 agent 对话自动化
# true = speak.latest_say 非空时自动写 scene_event{type:'dialogue'}；false = 回退 M4.2 行为
DIALOGUE_AUTO_EVENT_ENABLED=true
# plan.say 入 scene_event.content 的截断长度，超出加 …；与 prompts 的 200 字上限一致
DIALOGUE_CONTENT_MAX_LEN=200
# M4.3.1.b 回声保护参数（本节点仅记录，M4.3.1.b 消费）
# 回声保护窗口：最近 N tick 内的 pair 对话计数
DIALOGUE_ECHO_WINDOW_TICK=10
# 同一 NPC pair 在窗口内最多互相回应的轮数；超过触发硬阻断 + meta_warn
DIALOGUE_ECHO_MAX_TURN=3
