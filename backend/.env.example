# 服务器配置
PORT=3000

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=ainpc

# Redis（地图/NPC 实时状态，需先启动 Redis）
# 无密码：redis://localhost:6379 | 有密码：redis://:密码@localhost:6379
REDIS_URL=redis://:root@localhost:6379

# WebSocket 鉴权 token（开发期可固定）
WS_TOKEN=ainpc-dev-token

# NPC 自主移动是否使用 AI 决策（true=根据 ai_config 调用 LLM，false=纯随机）
WANDER_USE_AI=true
